<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Yummigo — AI-Powered Dining</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --gold:#C4902A;--gold2:#F2C46D;--gold3:#A87520;
  --gold-bg:rgba(196,144,42,0.11);--gold-b:rgba(196,144,42,0.28);
  --dark:#09090E;--s2:#17171F;--s3:#1E1E2A;--s4:#252535;
  --text:#F0EBE0;--muted:#7A7590;--border:rgba(212,166,71,0.14);
  --green:#2DB87A;--green-bg:rgba(45,184,122,0.12);--green-b:rgba(45,184,122,0.3);
  --red:#E05252;--red-bg:rgba(224,82,82,0.1);--red-b:rgba(224,82,82,0.28);
  --blue:#4A9AE8;--blue-bg:rgba(74,154,232,0.1);--blue-b:rgba(74,154,232,0.28);
  --amber:#D4A020;--amber-bg:rgba(212,160,32,0.1);--amber-b:rgba(212,160,32,0.28);
}
html,body{height:100%;font-family:'DM Sans',sans-serif;background:#050508;color:var(--text);overflow:hidden;-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{display:none}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-18px)}}
@keyframes floatX{0%,100%{transform:translate(0,0)}33%{transform:translate(12px,-14px)}66%{transform:translate(-8px,10px)}}
@keyframes slideIn{from{opacity:0;transform:translateX(24px)}to{opacity:1;transform:translateX(0)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(196,144,42,0.45)}50%{box-shadow:0 0 0 10px rgba(196,144,42,0)}}
@keyframes cookFill{from{width:0}to{width:42%}}
@keyframes toastIn{from{opacity:0;transform:translateX(-50%) translateY(-10px) scale(.95)}to{opacity:1;transform:translateX(-50%) translateY(0) scale(1)}}
@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
@keyframes fillBar{from{width:0}to{width:var(--w,80%)}}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
@keyframes wokFlame{0%,100%{transform:scaleY(1) rotate(-2deg)}50%{transform:scaleY(1.18) rotate(2deg)}}
@keyframes spark{0%{opacity:1;transform:translate(0,0) scale(1)}100%{opacity:0;transform:translate(var(--sx,20px),var(--sy,-40px)) scale(0)}}
@keyframes logoFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
@keyframes glowPulse{0%,100%{text-shadow:0 0 20px rgba(196,144,42,0)}50%{text-shadow:0 0 40px rgba(196,144,42,0.5)}}
@keyframes slideUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
@keyframes numberTick{from{transform:translateY(10px);opacity:0}to{transform:translateY(0);opacity:1}}
@keyframes otpShake{0%,100%{transform:translateX(0)}20%,60%{transform:translateX(-6px)}40%,80%{transform:translateX(6px)}}

.device{width:100vw;height:100vh;max-width:430px;margin:0 auto;position:relative;overflow:hidden;background:var(--dark)}
.scr{position:absolute;inset:0;display:none;flex-direction:column;background:var(--dark)}
.scr.active{display:flex;animation:slideIn .32s ease}
.scroll{flex:1;overflow-y:auto;padding:14px 16px 90px}
.ph{display:flex;align-items:center;gap:10px;padding:12px 16px 10px;flex-shrink:0;border-bottom:1px solid var(--border);background:rgba(9,9,14,.92);backdrop-filter:blur(12px)}
.bk{width:34px;height:34px;border-radius:10px;background:var(--s3);border:1px solid var(--border);color:var(--text);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .2s;font-family:inherit}
.bk:hover{background:var(--gold-bg);border-color:var(--gold-b);color:var(--gold)}
.ph-t{font-size:16px;font-weight:600;flex:1}.ph-s{font-size:11px;color:var(--muted);margin-top:1px}
.btn{width:100%;padding:13px 20px;background:linear-gradient(135deg,#A87520,#C4902A);border:none;border-radius:13px;color:#fff;font-size:15px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px}
.btn:hover{opacity:.88;box-shadow:0 6px 28px rgba(196,144,42,.4);transform:translateY(-1px)}
.btn:disabled{background:var(--s4);color:var(--muted);cursor:not-allowed;transform:none;box-shadow:none;opacity:1}
.gbtn{width:100%;padding:12px 20px;background:var(--s2);border:1px solid var(--border);border-radius:13px;color:var(--text);font-size:14px;font-weight:500;cursor:pointer;font-family:inherit;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px}
.gbtn:hover{background:var(--s3);border-color:var(--gold-b);color:var(--gold)}
.sbtn{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;padding:13px;border:1px solid var(--border);border-radius:13px;background:rgba(255,255,255,.04);color:var(--text);font-size:13px;font-weight:500;cursor:pointer;font-family:inherit;margin-bottom:10px;transition:all .2s}
.sbtn:hover{background:var(--gold-bg);border-color:var(--gold-b);transform:translateY(-1px)}
.finp{width:100%;padding:11px 14px;background:rgba(255,255,255,0.06);border:1px solid var(--border);border-radius:12px;color:var(--text);font-size:14px;font-family:inherit;outline:none;transition:all .25s}
.finp:focus{border-color:var(--gold-b);background:rgba(196,144,42,0.06);box-shadow:0 0 0 3px rgba(196,144,42,0.08)}
.finp::placeholder{color:var(--muted)}
select.finp option{background:#17171F}
input[type=time].finp{color-scheme:dark}
.card{background:var(--s2);border:1px solid var(--border);border-radius:18px;overflow:hidden;margin-bottom:13px}
.card.cl{cursor:pointer;transition:transform .22s,box-shadow .22s}
.card.cl:hover{transform:translateY(-3px);box-shadow:0 12px 36px rgba(0,0,0,.5)}
.cb{padding:14px 16px}
.chip{padding:8px 14px;border:1px solid var(--border);border-radius:100px;font-size:12px;cursor:pointer;transition:all .18s;background:var(--s2);color:var(--text);font-family:inherit}
.chip.on{background:var(--gold-bg);border-color:var(--gold-b);color:var(--gold);font-weight:500}
.badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:100px;font-size:11px;font-weight:500;white-space:nowrap}
.bg{background:var(--green-bg);border:1px solid var(--green-b);color:var(--green)}
.bb{background:var(--blue-bg);border:1px solid var(--blue-b);color:var(--blue)}
.ba{background:var(--amber-bg);border:1px solid var(--amber-b);color:var(--amber)}
.br{background:var(--red-bg);border:1px solid var(--red-b);color:var(--red)}
.bgo{background:var(--gold-bg);border:1px solid var(--gold-b);color:var(--gold)}
.mbar{margin-top:10px}
.mbar-lbl{display:flex;justify-content:space-between;font-size:11px;color:var(--muted);margin-bottom:4px}
.mbar-lbl span:last-child{color:var(--gold);font-weight:600}
.mtrack{height:5px;background:var(--s4);border-radius:3px;overflow:hidden}
.mfill{height:100%;background:linear-gradient(90deg,var(--gold),var(--gold2));border-radius:3px;animation:fillBar 1.3s ease forwards}
.tl-row{display:flex;gap:10px;align-items:flex-start}
.tl-dot{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0}
.tl-dot.dn{background:var(--green-bg);border:1.5px solid var(--green-b);color:var(--green)}
.tl-dot.ac{background:var(--gold-bg);border:1.5px solid var(--gold-b);color:var(--gold);animation:pulse 2s infinite}
.tl-dot.pd{background:var(--s4);border:1px solid var(--border);color:var(--muted)}
.tl-line{width:2px;min-height:16px;flex:1;margin:3px 0;border-radius:1px}
.tl-line.dn{background:var(--green-b)}.tl-line.pd{background:var(--border)}
.tl-ct{padding-bottom:18px;flex:1}
.tl-t{font-size:13px;font-weight:500;margin-bottom:3px}
.tl-s{font-size:11px;color:var(--muted);line-height:1.5}
.bnav{position:absolute;bottom:0;left:0;right:0;height:70px;background:rgba(9,9,14,.97);backdrop-filter:blur(16px);border-top:1px solid var(--border);display:flex;justify-content:space-around;align-items:center;padding:0 4px 10px;z-index:40}
.ni{display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer;padding:5px 10px;border-radius:10px;border:none;background:transparent;color:var(--muted);font-size:9px;font-family:inherit;font-weight:400;transition:all .2s;min-width:52px}
.ni.on{background:var(--gold-bg);color:var(--gold);font-weight:600}
.ni .ico{font-size:22px}
#toast{position:fixed;top:54px;left:50%;transform:translateX(-50%);padding:9px 20px;border-radius:100px;font-size:12px;font-weight:500;z-index:500;white-space:nowrap;display:none;pointer-events:none}
.ai-banner{background:linear-gradient(135deg,var(--gold-bg),rgba(232,164,90,.05));border:1px solid var(--border);border-radius:14px;padding:13px 15px;display:flex;gap:11px;align-items:flex-start;margin-bottom:14px}
.sep{display:flex;align-items:center;gap:10px;color:var(--muted);font-size:11px;margin:14px 0}
.sep::before,.sep::after{content:'';flex:1;height:1px;background:var(--border)}
.slabel{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;margin:0 0 13px;color:var(--text)}
.mlabel{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;font-weight:500;margin-bottom:10px}
.row-b{display:flex;justify-content:space-between;align-items:center}
.rescue-g{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.res-btn{padding:11px 7px;background:var(--s3);border:1px solid var(--border);border-radius:11px;font-size:12px;font-weight:500;cursor:pointer;color:var(--text);font-family:inherit;text-align:center;transition:all .2s}
.res-btn:hover{background:var(--s4);transform:translateY(-1px)}
.stat-g{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px}
.stat-c{background:var(--s2);border:1px solid var(--border);border-radius:12px;padding:10px 13px}
.stat-l{font-size:10px;color:var(--muted);margin-bottom:3px}
.stat-v{font-size:18px;font-weight:700}
.stat-u{font-size:10px;font-weight:400;color:var(--muted)}
.prog-w{height:5px;background:var(--s4);border-radius:3px;overflow:hidden;margin-top:7px}
.prog-b{height:100%;background:linear-gradient(90deg,var(--gold),var(--gold2));border-radius:3px;animation:cookFill 2.8s ease forwards}
.vote-bar-w{flex:1;height:7px;background:var(--s4);border-radius:4px;overflow:hidden}
.vote-bar{height:100%;background:linear-gradient(90deg,var(--gold),var(--gold2));border-radius:4px;transition:width .7s ease}
.tog{width:42px;height:23px;border-radius:12px;position:relative;cursor:pointer;transition:background .25s;border:none;flex-shrink:0;outline:none}
.tog.on{background:var(--green)}.tog.off{background:var(--s4);border:1px solid var(--border)}
.tog::after{content:'';position:absolute;width:17px;height:17px;border-radius:50%;background:#fff;top:2px;transition:left .22s;box-shadow:0 1px 4px rgba(0,0,0,.3)}
.tog.on::after{left:22px}.tog.off::after{left:2px}
.alert{padding:11px 14px;border-radius:12px;font-size:12px;line-height:1.55;display:flex;gap:9px;align-items:flex-start;margin-bottom:13px}
.alert.green{background:var(--green-bg);border:1px solid var(--green-b);color:var(--green)}
.alert.amber{background:var(--amber-bg);border:1px solid var(--amber-b);color:var(--amber)}
.alert.blue{background:var(--blue-bg);border:1px solid var(--blue-b);color:var(--blue)}
#login-canvas{position:absolute;inset:0;z-index:0}
.otp-boxes{display:flex;gap:10px;justify-content:center;margin:16px 0}
.otp-box{width:46px;height:54px;border-radius:13px;background:rgba(255,255,255,.06);border:1.5px solid var(--border);color:var(--text);font-size:22px;font-weight:700;text-align:center;outline:none;transition:all .22s;font-family:inherit}
.otp-box:focus{border-color:var(--gold-b);background:rgba(196,144,42,.08);box-shadow:0 0 0 3px rgba(196,144,42,.1)}
.dish-img-wrap{height:180px;position:relative;overflow:hidden}
.dish-img-wrap img{width:100%;height:100%;object-fit:cover;transition:transform .4s ease}
.card.cl:hover .dish-img-wrap img{transform:scale(1.06)}
.dish-img-overlay{position:absolute;bottom:0;left:0;right:0;height:70px;background:linear-gradient(to top,rgba(0,0,0,.7),transparent)}
.rest-img-wrap{height:160px;position:relative;overflow:hidden}
.rest-img-wrap img{width:100%;height:100%;object-fit:cover;transition:transform .4s ease}
.card.cl:hover .rest-img-wrap img{transform:scale(1.05)}
.loc-search{width:100%;padding:10px 14px 10px 38px;background:rgba(255,255,255,.06);border:1px solid var(--border);border-radius:12px;color:var(--text);font-size:13px;font-family:inherit;outline:none;transition:border .2s}
.loc-search:focus{border-color:var(--gold-b)}
.loc-search::placeholder{color:var(--muted)}
.country-list{max-height:220px;overflow-y:auto;background:var(--s2);border:1px solid var(--border);border-radius:12px;margin-top:6px}
.country-item{display:flex;align-items:center;gap:8px;padding:10px 14px;cursor:pointer;transition:background .15s;font-size:13px}
.country-item:hover{background:var(--s3)}
.country-item.sel{background:var(--gold-bg);color:var(--gold)}
.country-hdr{padding:6px 14px 3px;font-size:10px;color:var(--gold);text-transform:uppercase;letter-spacing:.8px;font-weight:600;background:var(--s3);cursor:default}
.msg{max-width:84%;padding:11px 14px;border-radius:17px;font-size:13px;line-height:1.56;margin-bottom:11px;animation:fadeUp .25s ease}
.msg.ai{background:var(--s2);border:1px solid var(--border);border-bottom-left-radius:4px;align-self:flex-start}
.msg.me{background:linear-gradient(135deg,#A87520,var(--gold));color:#fff;border-bottom-right-radius:4px;align-self:flex-end;margin-left:auto}
.ai-head{font-size:10px;color:var(--muted);font-weight:500;margin-bottom:5px}
.chat-area{display:flex;flex-direction:column;padding:14px 14px 10px;flex:1;overflow-y:auto}
.tdot{width:7px;height:7px;border-radius:50%;background:var(--muted);display:inline-block;animation:bounce .9s ease-in-out infinite}
.tbl-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:9px;max-width:295px;margin:0 auto 14px}
.tbl-btn{aspect-ratio:1;border-radius:10px;border:1.5px solid;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:11px;font-weight:500;background:transparent;font-family:inherit;transition:all .2s}
.tbl-btn.av{border-color:var(--green);color:var(--green);cursor:pointer}
.tbl-btn.av:hover,.tbl-btn.av.pk{background:var(--green-bg)}
.tbl-btn.rs{border-color:var(--gold);color:var(--gold);cursor:default}
.tbl-btn.oc{border-color:var(--red);color:var(--red);cursor:default}
.food-float{position:absolute;font-size:28px;pointer-events:none;animation:floatX 6s ease-in-out infinite;opacity:0.15}
.mode-tab{flex:1;padding:10px 8px;border:1px solid var(--border);color:var(--muted);font-size:13px;font-weight:500;cursor:pointer;font-family:inherit;transition:all .2s;background:var(--s3)}
.mode-tab.on{background:linear-gradient(135deg,#A87520,#C4902A);color:#fff;font-weight:600;border-color:transparent}
</style>
</head>
<body>
<div class="device" id="app">
<div id="toast"></div>

<!-- ══ LOGIN ══ -->
<div class="scr active" id="s-login">
  <canvas id="login-canvas"></canvas>
  <div class="food-float" style="top:12%;left:8%;animation-delay:0s;animation-duration:7s">🍜</div>
  <div class="food-float" style="top:22%;right:10%;animation-delay:1.5s;animation-duration:9s;font-size:22px">🍣</div>
  <div class="food-float" style="top:55%;left:5%;animation-delay:3s;animation-duration:8s;font-size:20px">🥟</div>
  <div class="food-float" style="top:65%;right:8%;animation-delay:2s;animation-duration:6s;font-size:24px">🍱</div>
  <div class="food-float" style="top:35%;right:5%;animation-delay:4s;animation-duration:10s;font-size:18px">🍵</div>
  <div class="food-float" style="top:78%;left:18%;animation-delay:0.5s;animation-duration:7.5s;font-size:20px">🥘</div>
  <div id="wok-scene" style="position:absolute;bottom:-10px;right:-20px;width:200px;height:200px;opacity:0.12;pointer-events:none;z-index:1">
    <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
      <ellipse cx="100" cy="140" rx="70" ry="28" fill="#8B4513" opacity=".7"/>
      <path d="M40 140 Q50 90 100 80 Q150 90 160 140" fill="#5D2E0C" stroke="#8B4513" stroke-width="4"/>
      <rect x="155" y="130" width="40" height="10" rx="5" fill="#666"/>
      <ellipse cx="100" cy="105" rx="30" ry="12" fill="#C4902A" opacity=".6" style="animation:wokFlame .8s ease-in-out infinite"/>
      <ellipse cx="90" cy="95" rx="16" ry="8" fill="#F2C46D" opacity=".5" style="animation:wokFlame .6s ease-in-out infinite;animation-delay:.2s"/>
      <circle cx="80" cy="80" r="4" fill="#F2C46D" opacity=".8" style="animation:spark 1.2s ease-out infinite;--sx:-15px;--sy:-30px"/>
      <circle cx="110" cy="75" r="3" fill="#C4902A" opacity=".8" style="animation:spark 1.5s ease-out infinite;animation-delay:.4s;--sx:12px;--sy:-25px"/>
      <circle cx="95" cy="70" r="2.5" fill="#fff" opacity=".6" style="animation:spark 1.8s ease-out infinite;animation-delay:.8s;--sx:-5px;--sy:-35px"/>
    </svg>
  </div>
  <div style="position:relative;z-index:2;padding:44px 24px 0;flex:1;display:flex;flex-direction:column">
    <div style="display:flex;align-items:center;gap:9px;margin-bottom:28px;animation:logoFloat 3s ease-in-out infinite">
      <svg width="32" height="32" viewBox="0 0 40 40" fill="none"><defs><linearGradient id="lg1" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#C4902A"/><stop offset="100%" stop-color="#F2C46D"/></linearGradient></defs><line x1="10" y1="3" x2="10" y2="16" stroke="url(#lg1)" stroke-width="3.5" stroke-linecap="round"/><line x1="18" y1="3" x2="18" y2="16" stroke="url(#lg1)" stroke-width="3.5" stroke-linecap="round"/><line x1="22" y1="3" x2="22" y2="10" stroke="url(#lg1)" stroke-width="2.5" stroke-linecap="round"/><line x1="10" y1="16" x2="14" y2="22" stroke="url(#lg1)" stroke-width="3.5" stroke-linecap="round"/><line x1="18" y1="16" x2="14" y2="22" stroke="url(#lg1)" stroke-width="3.5" stroke-linecap="round"/><line x1="14" y1="22" x2="14" y2="37" stroke="url(#lg1)" stroke-width="3.5" stroke-linecap="round"/><circle cx="30" cy="9" r="2.8" fill="url(#lg1)" opacity=".8"/><circle cx="34" cy="17" r="2" fill="url(#lg1)" opacity=".6"/></svg>
      <span style="font-family:'Playfair Display',serif;font-size:28px;font-weight:800;background:linear-gradient(135deg,#C4902A,#F2C46D);-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:glowPulse 3s ease-in-out infinite">Yummigo</span>
    </div>
    <div style="font-size:11px;color:var(--gold);letter-spacing:2.5px;text-transform:uppercase;margin-bottom:12px;animation:fadeUp .6s ease .2s both">&#10022; AI-Powered Dining</div>
    <h1 style="font-family:'Playfair Display',serif;font-size:38px;line-height:1.08;font-weight:800;margin-bottom:10px;animation:fadeUp .6s ease .3s both">Eat <span style="background:linear-gradient(135deg,#C4902A,#F2C46D);-webkit-background-clip:text;-webkit-text-fill-color:transparent">smarter,</span><br>dine better.</h1>
    <p style="color:var(--muted);font-size:13px;line-height:1.65;animation:fadeUp .6s ease .4s both">Your personal AI companion that knows what you crave before you do.</p>
    <div style="flex:1"></div>
  </div>
  <div style="position:relative;z-index:2;background:rgba(12,12,20,.97);backdrop-filter:blur(24px);border-top:1px solid var(--border);border-radius:30px 30px 0 0;padding:26px 22px 36px;animation:slideUp .5s ease .2s both">
    <div id="login-form">
      <button class="sbtn" onclick="go('s-loc')">
        <svg width="18" height="18" viewBox="0 0 18 18"><path d="M16.51 8H8.98v3h4.3c-.18 1-.74 1.48-1.6 2.04v2.01h2.6a7.8 7.8 0 002.38-5.88c0-.57-.05-.66-.15-1.17z" fill="#4285F4"/><path d="M8.98 17c2.16 0 3.97-.72 5.3-1.94l-2.6-2a4.8 4.8 0 01-7.18-2.54H1.83v2.07A8 8 0 008.98 17z" fill="#34A853"/><path d="M4.5 10.52a4.8 4.8 0 010-3.04V5.41H1.83a8 8 0 000 7.18l2.67-2.07z" fill="#FBBC05"/><path d="M8.98 4.18c1.17 0 2.23.4 3.06 1.2l2.3-2.3A8 8 0 001.83 5.4L4.5 7.48a4.77 4.77 0 014.48-3.3z" fill="#EA4335"/></svg>
        Continue with Google
      </button>
