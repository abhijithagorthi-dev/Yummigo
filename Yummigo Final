function togAdmin(k){
  ST.toggles[k]=!ST.toggles[k];
  var btn=document.getElementById('tog-'+k);
  if(btn){btn.classList.toggle('on',ST.toggles[k]);btn.classList.toggle('off',!ST.toggles[k]);}
  toast((ST.toggles[k]?'&#9989; Enabled: ':'&#10060; Disabled: ')+k,'green');
}

