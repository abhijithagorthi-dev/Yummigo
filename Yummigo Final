// ═══════ AI CHAT ═══════
function renderChat(){
  var a=document.getElementById('chat-area');if(!a)return;var h='';
  chatMsgs.forEach(function(m){
    if(m.r==='ai')h+='<div class="msg ai"><div class="ai-head">&#129302; Yummi &middot; AI Chef</div>'+m.t.replace(/\n/g,'<br>')+'</div>';
    else h+='<div style="display:flex;justify-content:flex-end"><div class="msg me">'+m.t+'</div></div>';
  });
  a.innerHTML=h;a.scrollTop=a.scrollHeight;
}
function sendQ(t){var el=document.getElementById('chat-inp');if(el)el.value=t;sendChat();}
function sendChat(){
  var inp=document.getElementById('chat-inp'),txt=inp.value.trim();if(!txt)return;inp.value='';
  chatMsgs.push({r:'user',t:txt});renderChat();
  var a=document.getElementById('chat-area');
  var td=document.createElement('div');td.id='typing-ind';
  td.style.cssText='display:flex;gap:5px;padding:11px 14px;background:var(--s2);border:1px solid var(--border);border-radius:17px;border-bottom-left-radius:4px;width:70px;margin-bottom:11px';
  [0,1,2].forEach(function(i){var d=document.createElement('div');d.className='tdot';d.style.animationDelay=i*0.22+'s';td.appendChild(d);});
  a.appendChild(td);a.scrollTop=a.scrollHeight;
  setTimeout(function(){
    var l=txt.toLowerCase(),rep=AI_R.def;
    if(l.includes('surprise')||l.includes('hidden'))rep=AI_R.surprise;
    else if(l.includes('pair')||l.includes('combo'))rep=AI_R.pair;
    else if(l.includes('trend')||l.includes('popular'))rep=AI_R.trend;
    else if(l.includes('romantic')||l.includes('date'))rep=AI_R.romantic;
    else if(l.includes('budget')||l.includes('cheap'))rep=AI_R.budget;
    var t=document.getElementById('typing-ind');if(t)t.remove();
    chatMsgs.push({r:'ai',t:rep});renderChat();
  },1000+Math.random()*600);
}

// ═══════ GROUP ═══════
function buildGroup(){
  var total=Object.values(ST.votes).reduce(function(a,b){return a+b;},0)+1;
  var h='';
  VOTE_D.forEach(function(d,i){
    var v=ST.votes[i]||0,pct=Math.round((v/total)*100);
    h+='<div style="display:flex;align-items:center;gap:10px;margin-bottom:'+(i<VOTE_D.length-1?'13':'0')+'px">';
    h+='<span style="font-size:28px;flex-shrink:0">'+d.e+'</span>';
    h+='<div style="flex:1"><div style="font-size:13px;font-weight:500;margin-bottom:5px">'+d.n+'</div>';
    h+='<div style="display:flex;align-items:center;gap:8px"><div class="vote-bar-w"><div class="vote-bar" style="width:'+pct+'%"></div></div>';
    h+='<span style="font-size:11px;color:var(--gold);font-weight:600;min-width:32px;text-align:right">'+pct+'%</span></div></div></div>';
  });
  document.getElementById('vote-list').innerHTML=h;
  h='';
  MEMBERS.forEach(function(m){
    var vd=m.d?m.v:(ST.myVote||'Voting...'),dn=m.d||!!ST.myVote;
    h+='<div style="display:flex;align-items:center;gap:10px;padding:10px 13px;background:var(--s2);border:1px solid var(--border);border-radius:12px;margin-bottom:8px">';
    h+='<div style="width:36px;height:36px;border-radius:50%;background:'+m.c+'22;color:'+m.c+';display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;flex-shrink:0">'+m.i+'</div>';
    h+='<div style="flex:1"><div style="font-size:13px;font-weight:500">'+m.n+'</div><div style="font-size:11px;color:var(--muted);margin-top:1px">'+vd+'</div></div>';
    h+=dn?'<span class="badge bg">&#10003; Voted</span>':'<span class="badge ba">Pending</span>';
    h+='</div>';
  });
  document.getElementById('member-list').innerHTML=h;
  h='';
  VOTE_D.forEach(function(d){
    var on=ST.myVote===d.n;
    h+='<button class="chip'+(on?' on':'')+'" onclick="pickVote(\''+d.n+'\')">'+d.e+' '+d.n+'</button>';
  });
  document.getElementById('my-votes').innerHTML=h;
}
function pickVote(n){ST.myVote=n;buildGroup();}
function castVote(){
  if(!ST.myVote){toast('&#9888; Please select a dish first','amber');return;}
  var idx=VOTE_D.findIndex(function(d){return d.n===ST.myVote;});
  if(idx>-1)ST.votes[idx]=(ST.votes[idx]||0)+1;
  toast('&#128499; Vote cast for '+ST.myVote+'! &#127881;','green');buildGroup();
}

