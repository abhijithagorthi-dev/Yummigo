function filterLocations(q){
  var list=document.getElementById('country-list');if(!list)return;
  var h='',count=0,ql=(q||'').toLowerCase().trim();
  LOCATIONS.forEach(function(loc){
    if(count>100)return;
    var mc=loc.c.toLowerCase().includes(ql);
    if(!ql){
      // Show all countries with their cities
      h+='<div class="country-hdr">'+loc.flag+' '+loc.c+'</div>';
      loc.cities.forEach(function(city){
        if(count>100)return;
        h+='<div class="country-item" onclick="pickLocation(\''+loc.flag+'\',\''+loc.c+'\',\''+city+'\')" style="padding-left:22px">&#128205; '+city+'</div>';
        count++;
      });
    } else if(mc){
      h+='<div class="country-item" onclick="pickLocation(\''+loc.flag+'\',\''+loc.c+'\',\'\')">'+loc.flag+' <strong>'+loc.c+'</strong> — all cities</div>';
      count++;
      loc.cities.forEach(function(city){
        if(count>100)return;
        h+='<div class="country-item" onclick="pickLocation(\''+loc.flag+'\',\''+loc.c+'\',\''+city+'\')" style="padding-left:22px">&#128205; '+city+'</div>';
        count++;
      });
    } else {
      loc.cities.forEach(function(city){
        if(count>100)return;
        if(city.toLowerCase().includes(ql)){
          h+='<div class="country-item" onclick="pickLocation(\''+loc.flag+'\',\''+loc.c+'\',\''+city+'\')">'+loc.flag+' '+city+', <strong>'+loc.c+'</strong></div>';
          count++;
        }
      });
    }
  });
  if(!h)h='<div style="padding:16px;text-align:center;color:var(--muted);font-size:13px">No results for "'+q+'"</div>';
  list.innerHTML=h;
}

